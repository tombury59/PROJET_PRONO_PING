{
	admin off
	auto_https off
	persist_config off
}

:{$PORT} {
	root * /var/www/html/public
	encode gzip zstd

	php_fastcgi 127.0.0.1:9000
	file_server

	log {
		output stdout
		format console
	}

	header {
		-Server
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
	}
}
