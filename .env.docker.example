# Copy this file to .env.docker and adjust as needed:
#   cp .env.docker.example .env.docker
#
# Used by docker-compose.yml (via env_file) for the "app" service.
# This is NOT read by the Dockerfile/image itself — on Render, these
# same variables are set directly in the service's environment tab
# (pointing at Supabase instead of the local "db" container).

APP_NAME=Prono
APP_ENV=local
APP_KEY=base64:REPLACE_ME_RUN_php_artisan_key_generate_show
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# Local docker-compose Postgres (see docker-compose.yml "db" service).
# For Render + Supabase, replace host/port/database/username/password
# with the values from Supabase > Project Settings > Database, and set
# DB_SSLMODE=require.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=prono
DB_USERNAME=prono
DB_PASSWORD=prono
DB_SSLMODE=disable

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

# Set to true to run `php artisan migrate --force` on every container
# boot. Handy while trying things out; for a real deploy prefer running
# migrations once (e.g. Render's "Pre-Deploy Command") instead of on
# every restart/scale event.
RUN_MIGRATIONS=true
